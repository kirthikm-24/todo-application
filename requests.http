### ============================================================
### TODO APP API DEMO REQUESTS
### ============================================================

### ------------------------------------------------------------
### 1. Get all tasks (Initially empty)
### ------------------------------------------------------------
GET http://localhost:8080/todos


### ------------------------------------------------------------
### 2. Create - Scheduled Task
### Status: SCHEDULED
### Vibe: PENDING
### ------------------------------------------------------------
POST http://localhost:8080/todos
Content-Type: application/json

{
  "name": "Design API",
  "description": "Design REST endpoints",
  "tentativeStartDate": "2026-07-15",
  "tentativeEndDate": "2026-07-20"
}


### ------------------------------------------------------------
### 3. Create - In Progress Task
### Status: IN_PROGRESS
### Vibe: PENDING
### ------------------------------------------------------------
POST http://localhost:8080/todos
Content-Type: application/json

{
  "name": "Implement Service Layer",
  "description": "Write business logic",
  "tentativeStartDate": "2026-07-15",
  "tentativeEndDate": "2026-07-20",
  "actualStartDate": "2026-07-16"
}


### ------------------------------------------------------------
### 4. Create - Completed Before Time
### Status: COMPLETED
### Vibe: DONE BEFORE TIME
### ------------------------------------------------------------
POST http://localhost:8080/todos
Content-Type: application/json

{
  "name": "Write Unit Tests",
  "description": "Mockito + JUnit",
  "tentativeStartDate": "2026-07-15",
  "tentativeEndDate": "2026-07-20",
  "actualStartDate": "2026-07-15",
  "actualEndDate": "2026-07-18"
}


### ------------------------------------------------------------
### 5. Create - Completed On Time
### Status: COMPLETED
### Vibe: DONE ON TIME
### ------------------------------------------------------------
POST http://localhost:8080/todos
Content-Type: application/json

{
  "name": "Complete Documentation",
  "description": "Prepare project docs",
  "tentativeStartDate": "2026-07-15",
  "tentativeEndDate": "2026-07-20",
  "actualStartDate": "2026-07-15",
  "actualEndDate": "2026-07-20"
}


### ------------------------------------------------------------
### 6. Create - Completed Late
### Status: COMPLETED
### Vibe: DELAYED BY 4 DAYS
### ------------------------------------------------------------
POST http://localhost:8080/todos
Content-Type: application/json

{
  "name": "Deploy Application",
  "description": "Production deployment",
  "tentativeStartDate": "2026-07-15",
  "tentativeEndDate": "2026-07-20",
  "actualStartDate": "2026-07-16",
  "actualEndDate": "2026-07-24"
}


### ------------------------------------------------------------
### 7. Get all tasks
### Observe different Status and Vibe values
### ------------------------------------------------------------
GET http://localhost:8080/todos


### ------------------------------------------------------------
### 8. Get task by valid ID
### ------------------------------------------------------------
GET http://localhost:8080/todos/1


### ------------------------------------------------------------
### 9. Get task by invalid ID
### Expected: 404 Not Found
### ------------------------------------------------------------
GET http://localhost:8080/todos/999


### ------------------------------------------------------------
### 10. Validation - Blank Name
### Expected: 400 Bad Request
### ------------------------------------------------------------
POST http://localhost:8080/todos
Content-Type: application/json

{
  "name": "",
  "description": "Validation test",
  "tentativeStartDate": "2026-07-15",
  "tentativeEndDate": "2026-07-20"
}


### ------------------------------------------------------------
### 11. Validation - Missing Tentative Dates
### Expected: 400 Bad Request
### ------------------------------------------------------------
POST http://localhost:8080/todos
Content-Type: application/json

{
  "name": "Missing Dates",
  "description": "Should fail validation"
}


### ------------------------------------------------------------
### 12. Business Validation - Invalid Date Range
### tentativeStartDate > tentativeEndDate
### Expected: 400 Bad Request
### ------------------------------------------------------------
POST http://localhost:8080/todos
Content-Type: application/json

{
  "name": "Invalid Dates",
  "description": "Business validation",
  "tentativeStartDate": "2026-07-25",
  "tentativeEndDate": "2026-07-20"
}


### ------------------------------------------------------------
### 13. Update Scheduled Task -> In Progress
### Status changes automatically
### ------------------------------------------------------------
PUT http://localhost:8080/todos/1
Content-Type: application/json

{
  "name": "Design API",
  "description": "Started implementation",
  "tentativeStartDate": "2026-07-15",
  "tentativeEndDate": "2026-07-20",
  "actualStartDate": "2026-07-16"
}


### ------------------------------------------------------------
### 14. Update In Progress -> Completed On Time
### Status and Vibe change automatically
### ------------------------------------------------------------
PUT http://localhost:8080/todos/1
Content-Type: application/json

{
  "name": "Design API",
  "description": "Completed successfully",
  "tentativeStartDate": "2026-07-15",
  "tentativeEndDate": "2026-07-20",
  "actualStartDate": "2026-07-16",
  "actualEndDate": "2026-07-20"
}


### ------------------------------------------------------------
### 15. Update Non-existent Task
### Expected: 404 Not Found
### ------------------------------------------------------------
PUT http://localhost:8080/todos/999
Content-Type: application/json

{
  "name": "Does not exist"
}


