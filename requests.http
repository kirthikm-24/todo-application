### H2 DATABASE QUERIES
### ============================================================

-- View all tasks (including soft-deleted)

-- View only active tasks
SELECT * FROM task WHERE deleted = false;

-- View soft-deleted tasks
SELECT * FROM task WHERE deleted = true;

-- Check status/vibe related fields
SELECT id, name, status, deleted FROM task;